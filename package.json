{
  "name": "pi-context-profiler",
  "version": "0.2.0",
  "private": true,
  "description": "Passive, content-free context attribution for Pi provider requests",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LovelyLoong/pi-context-profiler.git"
  },
  "homepage": "https://github.com/LovelyLoong/pi-context-profiler#readme",
  "bugs": {
    "url": "https://github.com/LovelyLoong/pi-context-profiler/issues"
  },
  "engines": {
    "node": ">=24 <26"
  },
  "files": [
    "extensions",
    "src",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "context-profiling"
  ],
  "scripts": {
    "check": "npm run typecheck && npm test",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "summarize": "node scripts/summarize.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
